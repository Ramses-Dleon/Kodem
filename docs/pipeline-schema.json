{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Kódem TCG Card Pipeline v2.1",
  "description": "Schema para definir pipelines de efectos de cartas. Cada carta tiene 1-N pipelines. v2.1: extensiones de zona, deferred, game-rules, source-filter.",
  "type": "object",
  "required": ["card_id", "card_name", "pipelines"],
  "properties": {
    "card_id": {
      "type": "string",
      "description": "Folio único de la carta (ej: CAMP-004)"
    },
    "card_name": {
      "type": "string",
      "description": "Nombre de la carta"
    },
    "effect_text": {
      "type": "string",
      "description": "Texto original del efecto (referencia)"
    },
    "cost_text": {
      "type": "string",
      "description": "Texto original del costo (referencia)"
    },
    "pipelines": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/pipeline" }
    },
    "game_rules": {
      "type": "array",
      "description": "Reglas persistentes que esta carta genera en el game state (rest-of-game effects)",
      "items": { "$ref": "#/definitions/game_rule" }
    },
    "meta": {
      "type": "object",
      "properties": {
        "role": { "type": "string", "enum": ["opener","closer","hitter","support","engine","disruptor","tech"] },
        "affinities": { "type": "array", "items": { "type": "string" } },
        "validated": { "type": "boolean", "default": false },
        "validated_by": { "type": "string" },
        "validated_at": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      }
    }
  },
  "definitions": {
    "pipeline": {
      "type": "object",
      "required": ["id", "trigger", "operation"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Identificador del pipeline (ej: P1-activa, P2-pasiva, P3-on-death)"
        },
        "label": {
          "type": "string",
          "description": "Descripción humana del pipeline"
        },
        "trigger": { "$ref": "#/definitions/trigger" },
        "prerequisites": {
          "type": "array",
          "items": { "$ref": "#/definitions/prerequisite" },
          "default": [{ "type": "independent" }]
        },
        "costs": {
          "type": "array",
          "items": { "$ref": "#/definitions/cost" },
          "default": [{ "type": "none" }]
        },
        "operation": {
          "type": "array",
          "minItems": 0,
          "items": { "$ref": "#/definitions/operation" },
          "description": "Operaciones ejecutadas en orden secuencial. Empty = cost-only (ej: Ariam Dualidad)"
        },
        "target": { "$ref": "#/definitions/target" },
        "restrictions": {
          "type": "array",
          "items": { "$ref": "#/definitions/restriction" },
          "default": []
        },
        "modifiers": { "$ref": "#/definitions/modifiers" },
        "deferred": { "$ref": "#/definitions/deferred" }
      }
    },

    "trigger": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "on-attack", "on-activate", "on-damaged", "on-reveal", "on-death",
            "on-equip", "on-healed", "on-link", "on-vivify",
            "on-ally-attack", "on-ally-damaged", "on-ally-reveal", "on-ally-death",
            "on-ally-hide", "on-ally-leaves-field", "on-ally-equip", "on-ally-link",
            "on-any-reveal", "on-any-healed", "on-any-death",
            "on-enemy-uses-drawn-effect",
            "on-equipped-attack", "on-equipped-damaged",
            "end-of-turn", "end-of-turn-expire", "on-poison", "on-rest-update",
            "on-pass-turn", "on-draw", "on-bio-extinct",
            "while-on-field", "while-in-zone", "unconditional", "conditional-self-destruct"
          ]
        },
        "fast": {
          "type": "boolean",
          "default": false,
          "description": "Activa-Rápida — se resuelve en ventana rápida de Batalla"
        },
        "zone": {
          "type": "string",
          "enum": ["field", "extinction", "equip-zone", "deck", "out-of-game", "any"],
          "default": "field",
          "description": "Zona desde donde esta carta puede activar el trigger. Default: field. Cartas como Mizthe Aura Mortal activan desde extinction."
        },
        "filter": { "$ref": "#/definitions/filter" }
      }
    },

    "prerequisite": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "independent",
            "once-per-game", "once-per-turn", "once-per-field",
            "min-extinction", "min-ext-type", "min-ext-name", "min-ext-same-energy",
            "min-count", "min-tokens",
            "needs-ally", "needs-same-name", "needs-equip", "needs-rava",
            "needs-protector", "needs-protector-available", "needs-bio",
            "needs-mark", "needs-link", "needs-named-protector",
            "self-hidden", "self-available",
            "no-own", "no-own-field",
            "target-has-mark", "target-has-rests",
            "total-damage-this-turn",
            "ally-stat-filter", "cards-vivified-count",
            "retroactive"
          ]
        },
        "value": {
          "description": "Valor numérico",
          "type": "integer"
        },
        "filter": { "$ref": "#/definitions/filter" },
        "name": {
          "type": "string",
          "description": "Nombre de carta para min-ext-name, needs-named-protector"
        },
        "mark": {
          "type": "string",
          "enum": ["burn", "poison", "abyss"]
        },
        "card_type": {
          "type": "string",
          "description": "Tipo para no-own (ej: bio, rava)"
        },
        "zones": {
          "type": "array",
          "items": { "type": "string", "enum": ["field", "extinction", "deck", "equip"] }
        },
        "stat": {
          "type": "string",
          "description": "Stat name for ally-stat-filter (ej: damage)"
        },
        "stat_op": {
          "type": "string",
          "enum": ["<=", ">=", "==", "<", ">"],
          "description": "Comparison operator for stat filter"
        },
        "stat_value": {
          "type": "integer"
        },
        "retroactive_note": {
          "type": "string",
          "description": "Explanation for retroactive prereqs (e.g., 'counts vivifies even before this card was in play')"
        }
      }
    },

    "cost": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "none",
            "self-damage", "ally-damage", "ally-damage-all", "field-damage-all",
            "self-extinct", "self-return-deck", "ally-extinct", "equip-extinct", "bio-extinct",
            "no-attack-this-turn", "lose-turn", "extra-rest",
            "protector-damage", "protector-rest",
            "pass-turn", "bio-passive-disabled",
            "mirror", "mirror-linked-stat",
            "cant-use-activa-while-active", "cant-return-to-equip",
            "custom-lookup"
          ]
        },
        "value": {
          "type": "integer"
        },
        "position": {
          "type": "string",
          "enum": ["top", "bottom"]
        },
        "filter": { "$ref": "#/definitions/filter" },
        "lookup_table": {
          "type": "object",
          "description": "For custom-lookup costs. Keys = condition values, values = cost amounts. Ex: Antón Escuadro Catrín { '4': 2, '5': 3, '6+': 4 }",
          "additionalProperties": { "type": "integer" }
        }
      }
    },

    "operation": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "damage", "damage-all", "damage-multi", "damage-per", "damage-as-revealed", "damage-protector",
            "damage-redistribute",
            "heal", "heal-all", "remove-marks",
            "burn", "poison", "abyss", "mark-persist",
            "scale", "scale-per", "descend", "reset-stats", "grant-double-damage", "attack-as",
            "rest-add", "rest-remove", "rest-set", "no-rest",
            "negate-effect", "negate-attack", "negate-passive-persistent", "conditional-negate",
            "protect-attack", "protect-effect", "immune-marks",
            "damage-reduce",
            "hide", "reveal", "reveal-all", "swap", "swap-field-extinction",
            "return-deck", "send-extinction", "vivify", "enhanced-replace",
            "deck-top-place", "peek-enemy-deck",
            "equip-from-extinct", "equip-from-equip-zone", "equip-self", "equip-destroy", "unequip-all", "extra-equip-slot",
            "change-subtype", "change-energy", "promote-to-fast", "grant-mark-on-attack",
            "grant-ability", "ban-vivify-names", "select-and-lock",
            "create-token", "copy", "feralizar",
            "redirect", "link", "possess",
            "attack-all", "attack-protector", "multi-attack",
            "swap-protector",
            "register-game-rule",
            "execute-from-zone", "check-win-condition",
            "create-token-parametric", "damage-cap",
            "amplify-effect", "stat-override",
            "equip-to-enemy", "swap-with-enemy"
          ]
        },
        "value": {
          "type": "integer"
        },
        "condition": {
          "description": "Condition for damage-per, scale-per, conditional-negate, attack-as, grant-ability",
          "oneOf": [
            { "type": "string" },
            { "$ref": "#/definitions/condition_expr" }
          ]
        },
        "mark": {
          "type": "string",
          "enum": ["burn", "poison", "abyss"]
        },
        "position": {
          "type": "string",
          "enum": ["top", "bottom"]
        },
        "hp": {
          "type": "integer",
          "description": "HP for vivify (default 6)"
        },
        "subtype": { "type": "string" },
        "energy": { "type": "string", "description": "For change-energy" },
        "source_zone": { "type": "string" },
        "source_filter": { "$ref": "#/definitions/filter" },
        "equip_type": { "type": "string", "enum": ["ixim", "rot", "any"] },
        "ability": {
          "type": "string",
          "description": "For grant-ability (ej: attack-protector, double-attack, extra-fast-response)"
        },
        "names": {
          "type": "array",
          "items": { "type": "string" },
          "description": "For ban-vivify-names: names chosen at runtime"
        },
        "game_rule": { "$ref": "#/definitions/game_rule" },
        "lookup_table": {
          "type": "object",
          "description": "For non-linear damage/scaling (e.g., Establo { '1': 1, '2': 3, '3': 6 })",
          "additionalProperties": { "type": "integer" }
        },
        "reduce_amount": {
          "type": "integer",
          "description": "For damage-reduce: reduce incoming damage by N"
        }
      }
    },

    "target": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["self", "ally", "enemy", "both", "facing", "protector", "any", "triggering", "equipped", "linked", "selected"]
        },
        "count": {
          "oneOf": [
            { "type": "integer", "minimum": 1 },
            { "type": "string", "enum": ["all"] }
          ]
        },
        "filter": { "$ref": "#/definitions/filter" },
        "players": {
          "type": "integer",
          "minimum": 1,
          "description": "For multiplayer: up to N rival players (default 1). Cards like Maiz Multicolor target up to 2 players."
        },
        "zone": {
          "type": "string",
          "enum": ["principal", "field", "extinction", "equip", "deck", "out-of-game"],
          "description": "Target zone if not default (field)"
        }
      }
    },

    "restriction": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "cant-attack", "cant-attack-protector", "cant-attack-on-reveal-turn",
            "cant-be-attacked", "cant-be-attacked-by",
            "cant-be-damaged-effect",
            "cant-equip", "cant-heal", "cant-heal-by-own-effects", "cant-be-protected", "cant-hide",
            "cant-rest-update", "cant-rest-update-more-than",
            "cant-link",
            "cant-negate", "cant-negate-passive", "cant-negate-active",
            "cant-be-copied",
            "cant-vivify", "cant-vivify-names",
            "immune-extinction-by-effect",
            "immune-to-drawn-effects",
            "target-filter",
            "source-filter",
            "cant-return-to-equip",
            "not-considered-protected"
          ]
        },
        "duration": { "$ref": "#/definitions/duration" },
        "filter": { "$ref": "#/definitions/filter" },
        "source_filter": {
          "$ref": "#/definitions/filter",
          "description": "Filter on the SOURCE of effects (who generates it). Ex: immune to effects from non-Catrín Adendei"
        },
        "names": {
          "type": "array",
          "items": { "type": "string" },
          "description": "For cant-vivify-names"
        },
        "value": { "type": "integer", "description": "For cant-rest-update-more-than" }
      }
    },

    "modifiers": {
      "type": "object",
      "properties": {
        "optional": { "type": "boolean", "default": false },
        "choice": {
          "oneOf": [
            { "type": "object", "properties": { "min": {"type":"integer"}, "max": {"type":"integer"} }, "required": ["min","max"] },
            { "type": "string", "enum": ["op"] }
          ]
        },
        "choice_operations": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "operation": { "type": "array", "items": { "$ref": "#/definitions/operation" } },
              "target": { "$ref": "#/definitions/target" },
              "costs": { "type": "array", "items": { "$ref": "#/definitions/cost" } }
            }
          },
          "description": "Alternative operation sets when choice='op'. Each has its own target and optional cost."
        },
        "duration": { "$ref": "#/definitions/duration" },
        "mirror_cost": { "type": "boolean", "default": false },
        "second_attack_suppresses_passives": { "type": "boolean", "description": "For double-attack: second attack doesn't trigger allied passives" }
      }
    },

    "deferred": {
      "type": "object",
      "description": "For pipelines that execute in two phases across turns. Phase 1: select/arm. Phase 2: execute when deferred_trigger fires.",
      "properties": {
        "phase1_operation": {
          "type": "string",
          "description": "What happens immediately (ej: 'select-target')"
        },
        "deferred_trigger": {
          "$ref": "#/definitions/trigger",
          "description": "When phase 2 executes (ej: on-protector-available, on-first-enemy-attack)"
        },
        "deferred_operation": {
          "type": "array",
          "items": { "$ref": "#/definitions/operation" },
          "description": "What executes in phase 2"
        },
        "expires": {
          "$ref": "#/definitions/duration",
          "description": "When the deferred effect expires if not triggered"
        }
      }
    },

    "game_rule": {
      "type": "object",
      "description": "Persistent game-state modification that outlives the card. Registered when pipeline executes, tracked by engine.",
      "required": ["id", "effect"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique rule identifier (ej: 'ariam-resurgimiento-buff')"
        },
        "effect": {
          "type": "string",
          "description": "What the rule does in human-readable form"
        },
        "applies_to": { "$ref": "#/definitions/filter" },
        "operations": {
          "type": "array",
          "items": { "$ref": "#/definitions/operation" }
        },
        "restrictions": {
          "type": "array",
          "items": { "$ref": "#/definitions/restriction" }
        },
        "duration": {
          "$ref": "#/definitions/duration",
          "description": "Almost always rest-of-game for game_rules"
        },
        "registered_by": {
          "type": "string",
          "description": "card_id that created this rule"
        }
      }
    },

    "condition_expr": {
      "type": "object",
      "description": "Structured condition for damage-per, scale-per, etc.",
      "properties": {
        "source": {
          "type": "string",
          "enum": [
            "extinction-count", "field-count", "same-energy-count",
            "damage-received-last-turn", "events-count-this-period",
            "target-rests", "target-stat",
            "lookup-table", "multi-energy-stat"
          ]
        },
        "filter": { "$ref": "#/definitions/filter" },
        "zone": { "type": "string" },
        "multiplier": { "type": "integer", "default": 1 },
        "lookup_table": {
          "type": "object",
          "additionalProperties": { "type": "integer" }
        },
        "energies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "For multi-energy-stat: which energies to count"
        }
      }
    },

    "filter": {
      "type": "object",
      "properties": {
        "energy": { "type": "string" },
        "subtype": { "type": "string" },
        "card_type": { "type": "string", "enum": ["adendei","rava","protector","bio","ixim","rot","espectro","token"] },
        "name": { "type": "string" },
        "negate": { "type": "boolean", "default": false },
        "or": {
          "type": "array",
          "items": { "$ref": "#/definitions/filter" }
        },
        "stat_filter": {
          "type": "object",
          "properties": {
            "stat": { "type": "string" },
            "op": { "type": "string", "enum": ["<=", ">=", "==", "<", ">"] },
            "value": { "type": "integer" }
          },
          "description": "Filter by stat value (ej: damage <= 2)"
        },
        "revealed": { "type": "boolean", "description": "Filter for revealed/hidden state" },
        "zone": { "type": "string", "enum": ["field","principal","extinction","equip","deck"] }
      }
    },

    "duration": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["permanent", "turn", "next-turn", "while-on-field", "next-attack", "next-N-attacks", "until-protector-available", "rest-of-game", "until-condition"]
        },
        "attack_count": { "type": "integer", "description": "For next-N-attacks duration" },
        "turns": { "type": "integer", "description": "For multi-turn durations" }
      }
    }
  }
}
